<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <NoWarn>1587;1591</NoWarn>

    <PackageId>SmartLegionLab.SmartPasswordLib</PackageId>
    <Version>1.0.0</Version>
    <Authors>Alexander Suvorov</Authors>
    <Company>SmartLegionLab</Company>
    <Product>SmartPasswordLib</Product>
    <Description>C# implementation of deterministic smart password generator. Same secret + same length = same password across all platforms.</Description>
    <Copyright>Copyright (c) 2026, Alexander Suvorov. All rights reserved.</Copyright>
    <PackageLicenseExpression>BSD-3-Clause</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/smartlegionlab/smartpasslib-csharp</PackageProjectUrl>
    <RepositoryUrl>https://github.com/smartlegionlab/smartpasslib-csharp</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>password;generator;security;cryptography;deterministic;smart-password;zero-storage</PackageTags>
  </PropertyGroup>

</Project>